# Database
DATABASE_URL=postgresql://user:password@localhost:5432/flashlounge

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Korapay
KORAPAY_SECRET_KEY=sk_live_your_korapay_secret_key
KORAPAY_PUBLIC_KEY=pk_live_your_korapay_public_key
KORAPAY_WEBHOOK_SECRET=your_webhook_secret

# Server
PORT=5000
NODE_ENV=development

# Admin seed (first run only)
ADMIN_EMAIL=admin@flashlounge.com
ADMIN_PASSWORD=changeme123

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
